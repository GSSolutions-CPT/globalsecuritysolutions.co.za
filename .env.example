# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: team user management API route
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OAuth callback and payment links (production URL)
NEXT_PUBLIC_SITE_URL=https://www.globalsecuritysolutions.co.za

# Optional: automated client emails via Resend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=notifications@globalsecuritysolutions.co.za
